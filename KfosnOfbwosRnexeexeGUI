-- Core logic (from original script, adapted)
local brick = ReplicatedStorage:FindFirstChild("Brick")
local paintTool = player.Backpack:FindFirstChild("Paint") or player.Character:FindFirstChild("Paint")
local remote = paintTool and (paintTool:FindFirstChild("Event", true) or paintTool:FindFirstChildWhichIsA("RemoteEvent", true))

local rootPos = player.Character and player.Character:FindFirstChild("HumanoidRootPart") and player.Character.HumanoidRootPart.Position or Vector3.new()

local key = "both \u{1F91D}"
local PURE_BLACK = Color3.fromRGB(0, 0, 0)

-- Get selected block color (from picker)
local selectedBlockColor = PURE_BLACK

blockColorPicker.MouseButton1Click:Connect(function()
    -- Simulate picker (expand to real UI later)
    selectedBlockColor = Color3.fromRGB(math.random(0,255), math.random(0,255), math.random(0,255))
    blockColorPicker.BackgroundColor3 = selectedBlockColor
end)

applyColorBtn.MouseButton1Click:Connect(function()
    if not remote or not brick then return end
    remote:FireServer(brick, Enum.NormalId.Top, rootPos, key, selectedBlockColor, "spray", "")  -- Using spray as base, adjust mode if needed
    StarterGui:SetCore("SendNotification", {Title = "¥harrz", Text = "Applied Input Color on Repstorage.", Duration = 4})
end)

toxBtn.MouseButton1Click:Connect(function()
    if not remote or not brick then return end
    remote:FireServer(brick, Enum.NormalId.Top, rootPos, key, PURE_BLACK, "toxic", "")
    StarterGui:SetCore("SendNotification", {Title = "¥harrz", Text = "Toxified RepStorage Block.", Duration = 4})
end)

unanchorBtn.MouseButton1Click:Connect(function()
    if not remote or not brick then return end
    if brick.Anchored then
        remote:FireServer(brick, Enum.NormalId.Top, rootPos, "material", PURE_BLACK, "anchor", "")
        StarterGui:SetCore("SendNotification", {Title = "¥harrz", Text = "Unanchored Repstorage.", Duration = 4})
    end
end)

applyTextBtn.MouseButton1Click:Connect(function()
    if not remote or not brick then return end
    
    -- Initial toxic black (as original)
    remote:FireServer(brick, Enum.NormalId.Top, rootPos, key, PURE_BLACK, "toxic", "")
    task.wait(0.2)
    
    -- Apply user texts + their colors to sides (random color fallback if picker not changed)
    local sides = {
        Enum.NormalId.Top,     -- Upside
        Enum.NormalId.Left,
        Enum.NormalId.Front,
        Enum.NormalId.Right,
        Enum.NormalId.Back,
        Enum.NormalId.Bottom   -- Downside
    }
    
    for i, sideEnum in ipairs(sides) do
        local sideName = sideNames[i]
        local txt = textBoxes[sideName].Text or ""
        local col = colorPickers[sideName].BackgroundColor3 or getRandomColor()  -- Fallback random if unchanged
        
        remote:FireServer(brick, sideEnum, rootPos, key, col, "spray", txt)
        task.wait(0.1)
    end
    
    -- Final neon
    remote:FireServer(brick, Enum.NormalId.Top, rootPos, "material", PURE_BLACK, "neon", "")
    
    StarterGui:SetCore("SendNotification", {Title = "¥harrz", Text = "Applied Text To Repstorage", Duration = 5})
end)

