local currentColorIndex = nil  -- For side colors
local isBaseColor = false

-- Function to open picker
local function openPicker(color, index, isBase)
    local r, g, b = math.floor(color.R * 255), math.floor(color.G * 255), math.floor(color.B * 255)
    rBox.Text = tostring(r)
    gBox.Text = tostring(g)
    bBox.Text = tostring(b)
    currentColorIndex = index
    isBaseColor = isBase
    colorPicker.Visible = true
end

-- Confirm picker
confirmButton.MouseButton1Click:Connect(function()
    local r = tonumber(rBox.Text)
    local g = tonumber(gBox.Text)
    local b = tonumber(bBox.Text)
    if r and g and b and r >= 0 and r <= 255 and g >= 0 and g <= 255 and b >= 0 and b <= 255 then
        local newColor = Color3.fromRGB(r, g, b)
        if isBaseColor then
            baseColor = newColor
            blockColorButton.BackgroundColor3 = newColor
        else
            sideColors[currentColorIndex] = newColor
            sideColorButtons[currentColorIndex].BackgroundColor3 = newColor
        end
        colorPicker.Visible = false
    else
        notify("Error", "Invalid RGB values")
    end
end)

