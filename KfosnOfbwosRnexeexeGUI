end

-- Helper to make a small labeled textbox for the picker
local function makeNumBox(parent, labelTxt, x, y, w, zIdx)
    local lbl = Instance.new("TextLabel")
    lbl.Size = UDim2.new(0, 18, 0, 16)
    lbl.Position = UDim2.new(0, x, 0, y)
    lbl.BackgroundTransparency = 1
    lbl.Text = labelTxt
    lbl.TextColor3 = Color3.fromRGB(190, 190, 190)
    lbl.Font = Enum.Font.Gotham
    lbl.TextSize = 10
    lbl.ZIndex = zIdx
    lbl.Parent = parent

    local box = Instance.new("TextBox")
    box.Size = UDim2.new(0, w, 0, 16)
    box.Position = UDim2.new(0, x + 18, 0, y)
    box.BackgroundColor3 = Color3.fromRGB(28, 20, 45)
    box.TextColor3 = Color3.fromRGB(230, 230, 230)
    box.PlaceholderText = "0"
    box.Text = "0"
    box.Font = Enum.Font.Code
    box.TextSize = 10
    box.ZIndex = zIdx
    box.Parent = parent
    Instance.new("UICorner", box).CornerRadius = UDim.new(0, 3)
    local s = Instance.new("UIStroke"); s.Color = Color3.fromRGB(60,60,100); s.Thickness = 1; s.Parent = box
    return box
end

