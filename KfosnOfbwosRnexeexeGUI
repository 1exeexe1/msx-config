-- ========================
-- TAB SYSTEM
-- ========================
local tabButtons = {}
local tabContents = {}

local function setActiveTab(name)
    activeTab = name
    for n, btn in pairs(tabButtons) do
        if n == name then
            btn.BackgroundColor3 = Color3.fromRGB(40, 180, 80)
            btn.TextColor3 = Color3.fromRGB(255, 255, 255)
        else
            btn.BackgroundColor3 = Color3.fromRGB(15, 10, 28)
            btn.TextColor3 = Color3.fromRGB(150, 200, 150)
        end
    end
    for n, frame in pairs(tabContents) do
        frame.Visible = (n == name)
    end
end

local function createTab(name)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, 0, 0, 30)
    btn.BackgroundColor3 = Color3.fromRGB(15, 10, 28)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(150, 200, 150)
    btn.Font = Enum.Font.GothamBold
    btn.TextSize = 12
    btn.ZIndex = 7
    btn.Parent = tabBar
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0,5)

    local content = Instance.new("ScrollingFrame")
    content.Size = UDim2.new(1, -8, 1, -8)
    content.Position = UDim2.new(0, 4, 0, 4)
    content.BackgroundTransparency = 1
    content.BorderSizePixel = 0
    content.ScrollBarThickness = 4
    content.ScrollBarImageColor3 = Color3.fromRGB(80, 200, 120)
    content.CanvasSize = UDim2.new(0, 0, 0, 0)
    content.Visible = false
    content.ZIndex = 6
    content.Parent = contentArea

    tabButtons[name] = btn
    tabContents[name] = content

    btn.MouseButton1Click:Connect(function()
        setActiveTab(name)
    end)

    return content
end

