-- Tab switching
local currentTab = "Home"

local function switchTab(tabName)
    homeContent.Visible = (tabName == "Home")
    opContent.Visible = (tabName == "OP")
end

homeTabBtn.MouseButton1Click:Connect(function() switchTab("Home") end)
opTabBtn.MouseButton1Click:Connect(function() switchTab("OP") end)

-- Toggle UI
