-- Bubble click with drag consideration
local bubbleDragging = false
local bubbleInitialPos = nil
local bubbleInitialMousePos = nil

bubble.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if dragEnabled then
            bubbleDragging = true
            bubbleInitialPos = bubble.Position
            local mouse = UserInputService:GetMouseLocation() or Vector2.new(0,0)
            bubbleInitialMousePos = mouse
        else
            toggleGui()
        end
    end
end)

bubble.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        if bubbleDragging then
            bubbleDragging = false
        elseif not dragEnabled then
            -- Already handled in Began
        end
    end
end)

UserInputService.InputChanged:Connect(function(input)
    if bubbleDragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local mouse = UserInputService:GetMouseLocation() or Vector2.new(0,0)
        local delta = mouse - bubbleInitialMousePos
        bubble.Position = UDim2.new(
            bubbleInitialPos.X.Scale, bubbleInitialPos.X.Offset + delta.X,
            bubbleInitialPos.Y.Scale, bubbleInitialPos.Y.Offset + delta.Y
        )
    end
end)

-- Main GUI drag
