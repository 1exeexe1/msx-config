-- Simple HSV color picker popup
local colorPickerOpen = false
local colorPickerFrame = nil
local colorPickerCallback = nil

local function closeColorPicker()
    if colorPickerFrame then
        colorPickerFrame:Destroy()
        colorPickerFrame = nil
        colorPickerOpen = false
    end
end

local function openColorPicker(anchorGui, callback)
    closeColorPicker()
    colorPickerOpen = true
    colorPickerCallback = callback

    local picker = Instance.new("Frame")
    picker.Name = "ColorPicker"
    picker.Size = UDim2.new(0, 220, 0, 200)
    picker.Position = UDim2.new(0.5, -110, 0.5, -100)
    picker.BackgroundColor3 = Color3.fromRGB(20, 15, 35)
    picker.BorderSizePixel = 0
    picker.ZIndex = 20
    picker.Parent = ScreenGui
    colorPickerFrame = picker

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 8)
    corner.Parent = picker

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(80, 200, 120)
    stroke.Thickness = 1.5
    stroke.Parent = picker

    local title = Instance.new("TextLabel")
    title.Size = UDim2.new(1, -30, 0, 28)
    title.Position = UDim2.new(0, 8, 0, 4)
    title.BackgroundTransparency = 1
    title.Text = "Pick Color"
    title.TextColor3 = Color3.fromRGB(200, 255, 200)
    title.Font = Enum.Font.GothamBold
    title.TextSize = 13
    title.ZIndex = 21
    title.Parent = picker

    local closeBtn = Instance.new("TextButton")
    closeBtn.Size = UDim2.new(0, 24, 0, 24)
    closeBtn.Position = UDim2.new(1, -28, 0, 4)
    closeBtn.BackgroundColor3 = Color3.fromRGB(200, 50, 50)
    closeBtn.Text = "X"
    closeBtn.TextColor3 = Color3.fromRGB(255,255,255)
    closeBtn.Font = Enum.Font.GothamBold
    closeBtn.TextSize = 11
    closeBtn.ZIndex = 22
    closeBtn.Parent = picker
    Instance.new("UICorner", closeBtn).CornerRadius = UDim.new(0,4)
    closeBtn.MouseButton1Click:Connect(closeColorPicker)

    -- HSV gradient canvas
    local canvas = Instance.new("ImageLabel")
    canvas.Size = UDim2.new(1, -16, 0, 110)
    canvas.Position = UDim2.new(0, 8, 0, 36)
    canvas.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    canvas.Image = "rbxassetid://698052001" -- HSV gradient
    canvas.ZIndex = 21
    canvas.Parent = picker

    local hueBar = Instance.new("ImageLabel")
    hueBar.Size = UDim2.new(1, -16, 0, 18)
    hueBar.Position = UDim2.new(0, 8, 0, 152)
    hueBar.Image = "rbxassetid://698053051" -- hue strip
    hueBar.BackgroundTransparency = 1
    hueBar.ZIndex = 21
    hueBar.Parent = picker

    local selectedH = 0
    local selectedS = 1
    local selectedV = 1

    local function updateColor()
        local c = Color3.fromHSV(selectedH, selectedS, selectedV)
        canvas.BackgroundColor3 = Color3.fromHSV(selectedH, 1, 1)
        if colorPickerCallback then
            colorPickerCallback(c)
        end
    end

    -- Hue drag
    local hueDragging = false
    hueBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
        end
    end)
    hueBar.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)

    -- SV drag
    local svDragging = false
    canvas.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
        end
    end)
    canvas.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
        end
    end)

    RunService.RenderStepped:Connect(function()
        if not colorPickerFrame then return end
        local pos = UserInputService:GetMouseLocation()
        if hueDragging then
            local abs = hueBar.AbsolutePosition
            local size = hueBar.AbsoluteSize
            selectedH = math.clamp((pos.X - abs.X) / size.X, 0, 1)
            updateColor()
        end
        if svDragging then
            local abs = canvas.AbsolutePosition
            local size = canvas.AbsoluteSize
            selectedS = math.clamp((pos.X - abs.X) / size.X, 0, 1)
            selectedV = 1 - math.clamp((pos.Y - abs.Y) / size.Y, 0, 1)
            updateColor()
        end
    end)

    -- Hex input
    local hexLabel = Instance.new("TextLabel")
    hexLabel.Size = UDim2.new(0, 60, 0, 18)
    hexLabel.Position = UDim2.new(0, 8, 0, 175)
    hexLabel.BackgroundTransparency = 1
    hexLabel.Text = "HEX:"
    hexLabel.TextColor3 = Color3.fromRGB(180,180,180)
    hexLabel.Font = Enum.Font.Gotham
    hexLabel.TextSize = 11
    hexLabel.ZIndex = 21
    hexLabel.Parent = picker

    local hexBox = Instance.new("TextBox")
    hexBox.Size = UDim2.new(0, 100, 0, 18)
    hexBox.Position = UDim2.new(0, 65, 0, 175)
    hexBox.BackgroundColor3 = Color3.fromRGB(30, 22, 50)
    hexBox.TextColor3 = Color3.fromRGB(255,255,255)
    hexBox.PlaceholderText = "FFFFFF"
    hexBox.Text = ""
    hexBox.Font = Enum.Font.Code
    hexBox.TextSize = 11
    hexBox.ZIndex = 21
    hexBox.Parent = picker
    Instance.new("UICorner", hexBox).CornerRadius = UDim.new(0,4)

    hexBox.FocusLost:Connect(function()
        local hex = hexBox.Text:gsub("#","")
        if #hex == 6 then
            local r = tonumber(hex:sub(1,2), 16)
            local g = tonumber(hex:sub(3,4), 16)
            local b = tonumber(hex:sub(5,6), 16)
            if r and g and b then
                local c = Color3.fromRGB(r,g,b)
                if colorPickerCallback then colorPickerCallback(c) end
            end
        end
    end)
end

