local sidesOrder = {"Top", "Left", "Front", "Right", "Back", "Bottom"}
local labels = {"Upside", "Leftside", "Frontside", "Rightside", "Backside", "Downside"}

-- Create 6 text + color rows
for i, side in ipairs(sidesOrder) do
    local row = Instance.new("Frame", opContent)
    row.Size = UDim2.new(1, 0, 0.12, 0)
    row.Position = UDim2.new(0, 0, (i-1)*0.125, 0)
    row.BackgroundTransparency = 1

    local textBtn = Instance.new("TextButton", row)
    textBtn.Size = UDim2.new(0.75, -10, 1, -4)
    textBtn.Position = UDim2.new(0, 5, 0, 2)
    textBtn.BackgroundColor3 = Color3.fromRGB(40, 40, 50)
    textBtn.Text = sideData[side].text
    textBtn.TextColor3 = Color3.new(0.9,0.9,0.9)
    textBtn.TextScaled = true
    textBtn.Font = Enum.Font.Gotham
    textBtn.TextXAlignment = Enum.TextXAlignment.Left

    local textCorner = Instance.new("UICorner", textBtn)
    textCorner.CornerRadius = UDim.new(0, 6)

    local border = Instance.new("UIStroke", textBtn)
    border.Color = Color3.fromRGB(0, 120, 255)
    border.Thickness = 2
    border.Transparency = 0.3

    -- Color preview square on right
    local colorPrev = Instance.new("Frame", row)
    colorPrev.Size = UDim2.new(0, 50, 0, 50)
    colorPrev.Position = UDim2.new(1, -60, 0.5, -25)
    colorPrev.BackgroundColor3 = sideData[side].color

    local colorCorner = Instance.new("UICorner", colorPrev)
    colorCorner.CornerRadius = UDim.new(0, 8)

    -- Click to "pick" (demo: random vibrant)
    colorPrev.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 then
            sideData[side].color = Color3.fromRGB(math.random(100,255), math.random(100,255), math.random(100,255))
            colorPrev.BackgroundColor3 = sideData[side].color
        end
    end)

    -- Update text when changed (user can type directly)
    textBtn.FocusLost:Connect(function(enterPressed)
        if enterPressed then
            sideData[side].text = textBtn.Text
        end
    end)
end

