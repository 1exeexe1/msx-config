    -- ── COLOR PREVIEW ──
    local preview = Instance.new("Frame")
    preview.Size = UDim2.new(0, 36, 0, 36)
    preview.Position = UDim2.new(1, -44, 0, 210)
    preview.BackgroundColor3 = Color3.fromRGB(255, 0, 0)
    preview.BorderSizePixel = 0
    preview.ZIndex = 21
    preview.Parent = picker
    Instance.new("UICorner", preview).CornerRadius = UDim.new(0,5)
    local prevStroke = Instance.new("UIStroke"); prevStroke.Color=Color3.fromRGB(80,200,120); prevStroke.Thickness=1.2; prevStroke.Parent=preview

    -- ── HEX INPUT (left side) ──
    local hexLbl = Instance.new("TextLabel")
    hexLbl.Size = UDim2.new(0, 28, 0, 16)
    hexLbl.Position = UDim2.new(0, 8, 0, 212)
    hexLbl.BackgroundTransparency = 1
    hexLbl.Text = "HEX"
    hexLbl.TextColor3 = Color3.fromRGB(190,190,190)
    hexLbl.Font = Enum.Font.Gotham
    hexLbl.TextSize = 10
    hexLbl.ZIndex = 21
    hexLbl.Parent = picker

    local hexBox = Instance.new("TextBox")
    hexBox.Size = UDim2.new(0, 72, 0, 16)
    hexBox.Position = UDim2.new(0, 36, 0, 212)
    hexBox.BackgroundColor3 = Color3.fromRGB(28, 20, 45)
    hexBox.TextColor3 = Color3.fromRGB(230, 230, 230)
    hexBox.PlaceholderText = "FF0000"
    hexBox.Text = "FF0000"
    hexBox.Font = Enum.Font.Code
    hexBox.TextSize = 10
    hexBox.ZIndex = 21
    hexBox.Parent = picker
    Instance.new("UICorner", hexBox).CornerRadius = UDim.new(0,3)
    local hs = Instance.new("UIStroke"); hs.Color=Color3.fromRGB(60,60,100); hs.Thickness=1; hs.Parent=hexBox

    -- ── RGB INPUTS (below hex) ──
    local rBox = makeNumBox(picker, "R", 8,   232, 32, 21)
    local gBox = makeNumBox(picker, "G", 62,  232, 32, 21)
    local bBox = makeNumBox(picker, "B", 116, 232, 32, 21)

    -- ── STATE ──
    local selectedH = 0
    local selectedS = 1
    local selectedV = 1
    local suppressSync = false -- prevent feedback loops

    local function syncInputsFromHSV()
        suppressSync = true
        local c = Color3.fromHSV(selectedH, selectedS, selectedV)
        local ri = math.floor(c.R * 255 + 0.5)
        local gi = math.floor(c.G * 255 + 0.5)
        local bi = math.floor(c.B * 255 + 0.5)
        hexBox.Text = string.format("%02X%02X%02X", ri, gi, bi)
        rBox.Text = tostring(ri)
        gBox.Text = tostring(gi)
        bBox.Text = tostring(bi)
        preview.BackgroundColor3 = c
        suppressSync = false
    end

    local function updateColor()
        local c = Color3.fromHSV(selectedH, selectedS, selectedV)
        -- Update SV square hue tint
        svOuter.BackgroundColor3 = Color3.fromHSV(selectedH, 1, 1)
        -- Update cursors
        hueCursor.Position = UDim2.new(selectedH, 0, 0.5, 0)
        svCursor.Position = UDim2.new(selectedS, 0, 1 - selectedV, 0)
        -- Update preview
        preview.BackgroundColor3 = c
        syncInputsFromHSV()
        if colorPickerCallback then
            colorPickerCallback(c)
        end
    end

    -- Initial state
    updateColor()

    -- ── DRAG INPUT ──
    local hueDragging = false
    local svDragging = false

    hueBar.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = true
            -- Immediate pick on click
            local abs = hueBar.AbsolutePosition
            local size = hueBar.AbsoluteSize
            local pos = UserInputService:GetMouseLocation()
            selectedH = math.clamp((pos.X - abs.X) / size.X, 0, 1)
            updateColor()
        end
    end)
    hueBar.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            hueDragging = false
        end
    end)

    svOuter.InputBegan:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = true
            local abs = svOuter.AbsolutePosition
            local size = svOuter.AbsoluteSize
            local pos = UserInputService:GetMouseLocation()
            selectedS = math.clamp((pos.X - abs.X) / size.X, 0, 1)
            selectedV = 1 - math.clamp((pos.Y - abs.Y) / size.Y, 0, 1)
            updateColor()
        end
    end)
    svOuter.InputEnded:Connect(function(i)
        if i.UserInputType == Enum.UserInputType.Touch or i.UserInputType == Enum.UserInputType.MouseButton1 then
            svDragging = false
        end
    end)

    local rsConn = RunService.RenderStepped:Connect(function()
        if not colorPickerFrame then return end
        local pos = UserInputService:GetMouseLocation()
        if hueDragging then
            local abs = hueBar.AbsolutePosition
            local size = hueBar.AbsoluteSize
            selectedH = math.clamp((pos.X - abs.X) / size.X, 0, 1)
            updateColor()
        end
        if svDragging then
            local abs = svOuter.AbsolutePosition
            local size = svOuter.AbsoluteSize
            selectedS = math.clamp((pos.X - abs.X) / size.X, 0, 1)
            selectedV = 1 - math.clamp((pos.Y - abs.Y) / size.Y, 0, 1)
            updateColor()
        end
    end)

    -- Clean up RenderStepped when picker closes
    local origClose = closeColorPicker
    -- patch: disconnect on next destroy
    picker.AncestryChanged:Connect(function()
        pcall(function() rsConn:Disconnect() end)
    end)

    -- ── HEX INPUT HANDLER ──
    hexBox.FocusLost:Connect(function()
        if suppressSync then return end
        local hex = hexBox.Text:gsub("#",""):upper()
        if #hex == 6 then
            local r = tonumber(hex:sub(1,2), 16)
            local g = tonumber(hex:sub(3,4), 16)
            local b = tonumber(hex:sub(5,6), 16)
            if r and g and b then
                local c = Color3.fromRGB(r, g, b)
                selectedH, selectedS, selectedV = Color3.toHSV(c)
                updateColor()
                if colorPickerCallback then colorPickerCallback(c) end
            end
        end
    end)

    -- ── RGB INPUT HANDLERS ──
    local function applyRGB()
        if suppressSync then return end
        local r = math.clamp(tonumber(rBox.Text) or 0, 0, 255)
        local g = math.clamp(tonumber(gBox.Text) or 0, 0, 255)
        local b = math.clamp(tonumber(bBox.Text) or 0, 0, 255)
        local c = Color3.fromRGB(r, g, b)
        selectedH, selectedS, selectedV = Color3.toHSV(c)
        updateColor()
        if colorPickerCallback then colorPickerCallback(c) end
    end
    rBox.FocusLost:Connect(applyRGB)
    gBox.FocusLost:Connect(applyRGB)
    bBox.FocusLost:Connect(applyRGB)
end

