-- Tab buttons (only Home & OP for now)
local tabButtons = {}
local tabContents = {}

local function createTab(name, index)
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(1, -10, 0, 50)
    btn.Position = UDim2.new(0, 5, 0, (index-1)*55)
    btn.BackgroundColor3 = Color3.fromRGB(40, 40, 60)
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(180, 255, 180)
    btn.Font = Enum.Font.GothamSemibold
    btn.TextScaled = true
    btn.Parent = tabsFrame
    
    local content = Instance.new("Frame")
    content.Size = UDim2.new(0.75, -10, 1, -60)
    content.Position = UDim2.new(0.25, 5, 0, 50)
    content.BackgroundTransparency = 1
    content.Visible = false
    content.Parent = mainFrame
    
    table.insert(tabButtons, btn)
    tabContents[name] = content
    
    btn.MouseButton1Click:Connect(function()
        for _, c in pairs(tabContents) do
            c.Visible = false
        end
        content.Visible = true
    end)
end

